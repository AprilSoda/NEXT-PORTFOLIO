# ─────────────────────────────────────────────────────────────
# Notion (official SDK) — database queries
# ─────────────────────────────────────────────────────────────
NOTION_TOKEN=               # Notion integration token (secret_...)
NOTION_DATABASE_ID=         # Works/Projects database id
NOTION_DATABASE_ID2=        # Blog posts database id

# ─────────────────────────────────────────────────────────────
# Notion (NotionX / notion-client) — full page rendering for blog detail
# ─────────────────────────────────────────────────────────────
NOTION_ACTIVE_USER=         # NotionX active user id (for private pages)
NOTION_AUTH_TOKEN=          # NotionX token_v2 (for private pages)

# ─────────────────────────────────────────────────────────────
# Contact form email (nodemailer / SMTP)
# ─────────────────────────────────────────────────────────────
MAIL_USER=                  # SMTP account (smtp.hiworks.com)
MAIL_PASS=                  # SMTP password
NEXT_PUBLIC_API_URL=        # Base URL for the contact form fetch (e.g. https://yourdomain.com)

# ─────────────────────────────────────────────────────────────
# Analytics (optional)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_ANALYTICS=   # GA4 measurement id (G-XXXXXXX)
# ─────────────────────────────────────────────────────────────
# Cloudflare R2 — image bucket (migration: scripts/migrate-images-to-r2.mjs)
# Create a bucket + API token in the Cloudflare dashboard. NEXT_PUBLIC_R2_PUBLIC_BASE
# is the public base URL (r2.dev now, custom domain later).
# ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=portfolio-images
NEXT_PUBLIC_R2_PUBLIC_BASE=